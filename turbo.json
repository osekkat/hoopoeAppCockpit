{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "HOST",
    "PORT",
    "VITE_WS_URL",
    "VITE_DEV_SERVER_URL",
    "HOOPOE_LOG_WS_EVENTS",
    "HOOPOE_MODE",
    "HOOPOE_PORT",
    "HOOPOE_HOME",
    "HOOPOE_AUTH_TOKEN",
    "HOOPOE_DESKTOP_WS_URL",
    "HOOPOE_TRACE_MIN_LEVEL",
    "HOOPOE_TRACE_TIMING_ENABLED",
    "HOOPOE_TRACE_FILE",
    "HOOPOE_TRACE_MAX_BYTES",
    "HOOPOE_TRACE_MAX_FILES",
    "HOOPOE_TRACE_BATCH_WINDOW_MS",
    "HOOPOE_OTLP_TRACES_URL",
    "HOOPOE_OTLP_METRICS_URL",
    "HOOPOE_OTLP_EXPORT_INTERVAL_MS",
    "HOOPOE_OTLP_SERVICE_NAME"
  ],
  "globalPassThroughEnv": ["PATHEXT"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "dist-electron/**", "bin/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": [],
      "cache": false
    },
    "test": {
      "dependsOn": ["^build"],
      "cache": false,
      "outputs": []
    }
  }
}
