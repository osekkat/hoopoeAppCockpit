{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hoopoe.local/conformance/dcg.schema.json",
  "title": "DCG normalized adapter output",
  "type": "object",
  "required": ["tool", "source", "state", "exit", "argv", "capabilities", "payload"],
  "properties": {
    "tool": { "const": "dcg" },
    "source": { "enum": ["fixture", "local"] },
    "state": { "type": "string" },
    "exit": { "type": "integer" },
    "argv": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "capabilities": { "type": "object" },
    "payload": {
      "type": "object",
      "required": ["probe"],
      "properties": {
        "probe": {
          "type": "object",
          "required": ["statusCommandAccepted", "stderrText"],
          "properties": {
            "statusCommandAccepted": { "type": "boolean" },
            "stderrText": { "type": "string" }
          }
        }
      }
    }
  }
}
