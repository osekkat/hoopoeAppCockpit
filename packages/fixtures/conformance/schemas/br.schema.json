{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hoopoe.local/conformance/br.schema.json",
  "title": "br normalized adapter output",
  "type": "object",
  "required": ["tool", "source", "state", "exit", "argv", "capabilities", "payload"],
  "properties": {
    "tool": { "const": "br" },
    "source": { "enum": ["fixture", "local"] },
    "state": { "type": "string" },
    "exit": { "type": "integer" },
    "argv": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "capabilities": { "type": "object" },
    "payload": {
      "type": "object",
      "required": ["issues", "total", "limit", "offset", "has_more"],
      "properties": {
        "issues": { "type": "array" },
        "total": { "type": "integer", "minimum": 0 },
        "limit": { "type": "integer", "minimum": 0 },
        "offset": { "type": "integer", "minimum": 0 },
        "has_more": { "type": "boolean" }
      }
    }
  }
}
