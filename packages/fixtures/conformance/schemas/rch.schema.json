{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hoopoe.local/conformance/rch.schema.json",
  "title": "rch normalized adapter output",
  "type": "object",
  "required": ["tool", "source", "state", "exit", "argv", "capabilities", "payload"],
  "properties": {
    "tool": { "const": "rch" },
    "source": { "enum": ["fixture", "local"] },
    "state": { "type": "string" },
    "exit": { "type": "integer" },
    "argv": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "capabilities": { "type": "object" },
    "payload": {
      "type": "object",
      "required": ["statusText", "daemon", "posture", "workers", "builds"],
      "properties": {
        "statusText": { "type": "string", "minLength": 1 },
        "daemon": { "type": "string", "minLength": 1 },
        "posture": { "type": "string" },
        "workers": { "type": "string" },
        "builds": { "type": "string" }
      }
    }
  }
}
