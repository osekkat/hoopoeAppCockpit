# bv (beads viewer) local config and caches
.bv/

# Node/Bun/Turbo
node_modules
.bun
.turbo
*.log
*.tsbuildinfo
# Note: bun.lock IS committed for reproducibility (t3code pattern)

# Build outputs
apps/*/dist
apps/*/dist-electron
packages/*/dist
build/
release/
release-mock/

# Go build artifacts (stray binaries when `go build ./...` runs from apps/daemon)
apps/daemon/bin/
apps/daemon/hoopoe
apps/daemon/*.test
apps/daemon/coverage.out

# Editor / OS
.DS_Store
.idea/
.vscode/

# Env
.env
.env.local

# Hoopoe runtime artifacts
.hoopoe/
.logs/
.t3
.tanstack
.vitest-*

# SLB (safety lockbox) runtime state
.slb/

# SQLite runtime DB (daemon read-model cache, not canonical)
/storage.sqlite3
/storage.sqlite3-shm
/storage.sqlite3-wal

# NTM working state (per-pane; excluded from VCS)
.ntm/

# Claude Code session state
.claude/

# Playwright test results
**/test-results/
**/playwright-report/

# Test-evidence envelopes (hp-6sv) — generated per run; uploaded to CI artifact
# storage, never committed. The conventions live in docs/testing.md.
docs/test-evidence/

# Orchestrator nudge files (per-pane scratch from swarm dispatches)
/p[0-9]_*.txt
/p[0-9][0-9]_*.txt
/review_*.txt
/marching_orders*.txt

# Phase 0 evidence-pack landing zones (raw tarballs; extracted tree is committed)
packages/fixtures/phase0-*/incoming/
