  },
  "include": [
    "src",
    "electron",
    "../../packages/fixture-replay/src",
    "../../packages/fixtures/src",
    "../../packages/fixtures/replay",
    "../../packages/schemas/src"
  ],
  "exclude": ["**/*.test.ts", "**/*.test.tsx"]
}
