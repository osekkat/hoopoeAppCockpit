{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "jsx": "react-jsx",
    "types": ["bun", "node"],
    "lib": ["ESNext", "DOM", "esnext.disposable"],
    "baseUrl": ".",
    "paths": {
      "@hoopoe/fixture-replay": ["../../packages/fixture-replay/src/index.ts"],
      "@hoopoe/fixtures": ["../../packages/fixtures/src/index.ts"],
      "@hoopoe/schemas": ["../../packages/schemas/src/index.ts"]
