{
  "name": "@hoopoe/desktop",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist-electron/electron-entry.js",
  "scripts": {
    "build": "vite build && tsdown src/main.ts src/electron-entry.ts --format esm --platform node --external electron --out-dir dist-electron --no-clean && tsdown electron/preload.ts --format cjs --platform node --external electron --out-dir dist-electron --no-clean && cp dist-electron/main.mjs dist-electron/main.js && cp dist-electron/electron-entry.mjs dist-electron/electron-entry.js && cp dist-electron/preload.cjs dist-electron/preload.js && bun scripts/assert-preload-cjs.ts",
    "dev": "vite --host 127.0.0.1",
    "e2e": "playwright test -c ../../playwright.config.ts",
    "e2e:phase1": "playwright test -c tests/e2e/hp-j30.playwright.config.ts",
    "e2e:command-palette": "playwright test -c tests/e2e/command-palette.playwright.config.ts",
    "test:smoke": "bun test tests/smoke/*.test.ts",
    "test:phase1": "bun test tests/unit/*.test.ts",
    "test:replay": "bun test tests/replay/*.test.ts",
    "test:integration": "bun test tests/integration/**/*.test.ts",
    "e2e:replay": "bun test tests/replay/*.test.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "bun test src tests/smoke/*.test.ts tests/unit/*.test.ts tests/replay/*.test.ts tests/integration/**/*.test.ts electron/*.test.ts electron/**/*.test.ts scripts/*.test.ts"
  },
  "dependencies": {
    "@codemirror/commands": "^6.7.1",
    "@codemirror/lang-markdown": "^6.3.1",
    "@codemirror/language": "^6.10.4",
    "@codemirror/state": "^6.5.0",
    "@codemirror/view": "^6.34.3",
    "@hoopoe/design-system": "workspace:*",
    "@hoopoe/fixture-replay": "workspace:*",
    "@hoopoe/fixtures": "workspace:*",
    "@hoopoe/problem-types": "workspace:*",
    "@hoopoe/schemas": "workspace:*",
    "@hoopoe/test-evidence": "workspace:*",
    "@tanstack/react-query": "^5.100.8",
    "@tanstack/react-router": "^1.0.0",
    "@xyflow/react": "^12.10.2",
    "electron": "40.9.3",
    "electron-updater": "^6.6.2",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "ssh2": "^1.17.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ssh2": "^1.15.5",
    "@vitejs/plugin-react": "^5.0.0",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vite": "^8.0.0"
  },
  "productName": "Hoopoe"
}
