{
  "name": "@hoopoe/monorepo",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/desktop",
      "apps/daemon",
      "packages/schemas",
      "packages/design-system",
      "packages/fixtures",
      "packages/fixture-replay",
      "packages/test-evidence",
      "packages/slo",
      "packages/tending-actions",
      "packages/problem-types",
      "packages/planning-prompts"
    ],
    "catalog": {
      "@types/bun": "^1.3.13",
      "@types/node": "^24.10.13",
      "tsdown": "^0.20.3",
      "typescript": "^5.9.2",
      "vitest": "^4.0.0"
    }
  },
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "e2e": "bun scripts/e2e/run-e2e.ts",
    "e2e:desktop:smoke": "playwright test -c playwright.config.ts",
    "e2e:desktop:phase1": "bun run --cwd apps/desktop e2e:phase1",
    "mock-flywheel": "bun test packages/fixtures/test/golden-replay.test.ts apps/desktop/src/main/MockFlywheelMode.test.ts apps/desktop/src/main/LocalDemoBootstrap.test.ts apps/desktop/tests/unit/hp-j30-phase1.test.ts",
    "typecheck": "turbo run typecheck",
    "test": "bun run test:provider-sdks && bun run test:renderer-isolation && bun run test:codex-shape-scrub && bun run test:desktop-helper-boundary && bun run test:no-raw-logging && bun run test:redact-drift && turbo run test",
    "test:desktop:release": "bun test apps/desktop/tests/release/*.test.ts",
    "test:provider-sdks": "bun test scripts/providerlint/check-provider-sdks.test.ts",
    "test:renderer-isolation": "bun test scripts/rendererlint/check-renderer-isolation.test.ts",
    "test:codex-shape-scrub": "bun test scripts/codex-shape-scrub/check-codex-shape-scrub.test.ts",
    "test:desktop-helper-boundary": "bun test scripts/desktop-helper-boundary/check-desktop-helper-boundary.test.ts",
    "test:no-raw-logging": "bun test scripts/loggerlint/check-no-raw-logging.test.ts",
    "test:redact-drift": "bun test scripts/redactlint/check-redact-drift.test.ts",
    "lint": "bun run lint:provider-sdks && bun run lint:renderer-isolation && bun run lint:codex-shape-scrub && bun run lint:desktop-helper-boundary && bun run lint:no-raw-logging && bun run lint:redact-drift && oxlint --report-unused-disable-directives",
    "lint:provider-sdks": "bun scripts/providerlint/check-provider-sdks.ts",
    "lint:renderer-isolation": "bun scripts/rendererlint/check-renderer-isolation.ts",
    "lint:codex-shape-scrub": "bun scripts/codex-shape-scrub/check-codex-shape-scrub.ts",
    "lint:desktop-helper-boundary": "bun scripts/desktop-helper-boundary/check-desktop-helper-boundary.ts",
    "lint:no-raw-logging": "bun scripts/loggerlint/check-no-raw-logging.ts",
    "lint:redact-drift": "bun scripts/redactlint/check-redact-drift.ts",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "clean": "rm -rf node_modules apps/*/node_modules packages/*/node_modules apps/*/dist apps/*/dist-electron packages/*/dist .turbo apps/*/.turbo packages/*/.turbo"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "catalog:",
    "oxfmt": "^0.40.0",
    "oxlint": "^1.55.0",
    "turbo": "^2.3.3",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "bun": "^1.3.11",
    "node": "^24.13.1"
  },
  "packageManager": "bun@1.3.13",
  "trustedDependencies": [
    "electron"
  ]
}
