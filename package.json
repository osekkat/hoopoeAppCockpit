{
  "name": "@hoopoe/monorepo",
  "private": true,
  "type": "module",
  "workspaces": {
    "packages": [
      "apps/desktop",
      "apps/daemon",
      "packages/schemas",
      "packages/design-system",
      "packages/fixtures"
    ],
    "catalog": {
      "@types/bun": "^1.3.13",
      "@types/node": "^24.10.13",
      "tsdown": "^0.20.3",
      "typescript": "^5.9.2",
      "vitest": "^4.0.0"
    }
  },
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "bun run test:provider-sdks && turbo run test",
    "test:provider-sdks": "bun test scripts/providerlint/check-provider-sdks.test.ts",
    "lint": "bun run lint:provider-sdks && oxlint --report-unused-disable-directives",
    "lint:provider-sdks": "bun scripts/providerlint/check-provider-sdks.ts",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "clean": "rm -rf node_modules apps/*/node_modules packages/*/node_modules apps/*/dist apps/*/dist-electron packages/*/dist .turbo apps/*/.turbo packages/*/.turbo"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "oxfmt": "^0.40.0",
    "oxlint": "^1.55.0",
    "turbo": "^2.3.3",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "bun": "^1.3.11",
    "node": "^24.13.1"
  },
  "packageManager": "bun@1.3.13",
  "trustedDependencies": [
    "electron"
  ]
}
